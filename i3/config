### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term wezterm

### Output & Visuals
# Replacement for 'output' commands
exec_always --no-startup-id feh --bg-fill ~/dot_files/wallpaper/wallpaper_clean.jpg
exec_always --no-startup-id xrandr --output ANY --mode 1920x1080

# Gaps (Requires i3-gaps or i3-wm version 4.22+)
gaps inner 3
gaps outer 3
default_border pixel 0

# Compositor (Crucial for transparency/smoothness in X11)
exec_always --no-startup-id picom -b

### Idle & Autostart
# Replacement for swayidle/swaylock
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -n -c 000000

# Replacement for autotiling (using the python script mentioned in the list)
exec_always --no-startup-id autotiling

exec --no-startup-id $term

### Input configuration (X11 style)
# i3 doesn't handle this directly. Use 'setxkbmap' and 'xinput'
exec_always --no-startup-id setxkbmap -layout us -variant altgr-intl -option "lvl3:rctrl"
exec_always --no-startup-id numlockx on

focus_follows_mouse no

### Key bindings
bindsym $mod+Shift+q kill
bindsym $mod+Return exec wezterm start --always-new-process
bindsym $mod+Space exec rofi -show combi

# Apps
bindsym $mod+w exec firefox
bindsym $mod+e exec thunar

floating_modifier $mod normal

# Reload/Restart
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Exit i3 (Simplified replacement for swaynag)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# Clipboard (Using xclip/rofi replacement for cliphist)
bindsym $mod+c exec "rofi -modi 'clipboard:greenclip print' -show clipboard"

# Moving around:
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# Workspaces:
bindsym $mod+1 workspace number 1
# ... (repeat for 2-0 as per your sway config)
bindsym $mod+Shift+1 move container to workspace number 1
# ... (repeat for 2-0)

# Layout stuff:
bindsym $mod+s splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+ctrl+space focus mode_toggle
bindsym $mod+a focus parent

# Scratchpad:
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Resizing containers:
mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Utilities:
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym XF86MonBrightnessUp exec brightnessctl set 5%+

# Screenshots (Replacement for grim/slurp)
bindsym $mod+y exec maim -s | xclip -selection clipboard -t image/png
bindsym Print exec maim | xclip -selection clipboard -t image/png

# Status Bar:
bar {
    position top
    status_command i3status
}
