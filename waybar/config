 {
  "layer": "top",
  "spacing": 5,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [],
  "modules-right": [
    "network",
    "group/group-backlight",
    "group/group-audio",
    "battery",
    "clock",
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "on-click": "activate"
  },
  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "exec": "~/.config/waybar/scripts/wabar-wttr.py",
    "return-type": "json"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "clock": {
    "format": "{:%a %d %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "on-scroll": { "calendar": 1 },
    "calendar" : {
        "on-scroll": 1,
        "format" : {
            "today": "<span color='#a6e3af'><b><u>{}</u></b></span>"
        }
    }
  },
  "network": {
    "interface": "wlan0",
    "format-icons": ["󰤟","󰤢","󰤥","󰖩"],
    "format": "󰤭", 
    "format-wifi":"{icon}",
    "format-disconnected": "󰤭",
    "format-ethernet": "{ipaddr}/{cidr}󰊗",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname}",
    "max-length": 50
  },
    "group/group-audio": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "",
            "transition-left-to-right": false,
        },
        "modules": [
            "pulseaudio",
            "pulseaudio/slider",
        ]
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}",
        "format-muted": "󰝟",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "speaker": "󰕾",
            "hdmi": "󰓃",
            "headphone": "󰋋",
            "hands-free": "?",
            "headset": "󰋎",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click-right": "pavucontrol",
        "on-click": "amixer set Master toggle",
    },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " ",
      "deactivated": " "
    },
    "tooltip": false
  },
  "custom/power-menu": {
    "format": "⏻",
    "on-click": "~/.config/waybar/scripts/power-menu/powermenu.sh"
  },
  "battery": {
    "interval": 10,
    "states": {
      "warning": 50,
      "critical": 20
    },
    "format": "{icon}",
    "format-icons": {
        "default": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "charging": ["󰢟", "󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"]
    },
    "format-warning": "<span color='#f9e2af'>{icon}</span>",
    "format-critical": "<span color='#f38ba8'>{icon}</span>",
    "format-charging-warning": "<span color='#f9e2af'>{icon}</span>",
    "format-charging-critical": "<span color='#f38ba8'>{icon}</span>",
    "tooltip-format": "{capacity}%",
  },
    "group/group-backlight": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "",
            "transition-left-to-right": false,
        },
        "modules": [
            "backlight",
            "backlight/slider",
        ]
    },
    "backlight": {
        "device": "intel_backlight",
        "tooltip": false,
        "format": "{icon}",
        "format-icons": [
            "󰃞", "󰃟", "󰃠"
        ],
        "on-click": "brightnessctl set 5%+",
        "on-click-right": "brightnessctl set 5%-",
        "tooltip-format": "{percent}%"
  },
}
