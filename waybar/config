{
    "layer": "top",
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "custom/playerctl",
        "tray",
        "idle_inhibitor",
        "network",
        "group/group-backlight",
        "group/group-audio",
        "battery",
        "clock",
    ],
    "sway/workspaces": {
        "format": "{name}",
    },
    "tray": {
        "icon-size": 12,
        "spacing": 5
    },
    "clock": {
        "format": "{:%a %d %H:%M}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "timezone": "America/Argentina/Buenos_Aires",
        "on-scroll": { "calendar": 1 },
        "calendar" : {
            "on-scroll": 1,
            "format" : {
                "today": "<span color='#a6e3af'><b><u>{}</u></b></span>"
            }
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "network": {
        "format-icons": ["󰤟","󰤢","󰤥","󰖩"],
        "format-wifi":"{icon}",
        "format-disconnected": "󰤭",
        "format-ethernet": "{ipaddr}/{cidr}󰊗",
        "tooltip-format": "{ifname} via {gwaddr}",
        "tooltip-format-wifi": "{essid}",
        "tooltip-format-ethernet": "{ifname}",
        "max-length": 50
    },
    "group/group-audio": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "",
            "transition-left-to-right": false,
        },
        "modules": [
            "pulseaudio",
            "pulseaudio/slider",
        ]
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}",
        "format-muted": "󰝟",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "speaker": "󰕾",
            "hdmi": "󰓃",
            "headphone": "󰋋",
            "hands-free": "?",
            "headset": "󰋎",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click-right": "pavucontrol",
        "on-click": "amixer set Master toggle",
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 50,
            "critical": 20
        },
        "format": "<span color='#a6e3a1'>{icon}</span>",
        "format-icons": {
            "default": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
            "charging": ["󰢟", "󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"]
        },
        "format-warning": "<span color='#f9e2af'>{icon}</span>",
        "format-critical": "<span color='#f38ba8'>{icon}</span>",
    "tooltip-format": "{capacity}%",
    },
    "group/group-backlight": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "",
            "transition-left-to-right": false,
        },
        "modules": [
            "backlight",
            "backlight/slider",
        ]
    },
    "backlight": {
        "device": "intel_backlight",
        "tooltip": false,
        "format": "{icon}",
        "format-icons": [
            "󰃞", "󰃟", "󰃠"
        ],
        "on-click": "brightnessctl set 5%+",
        "on-click-right": "brightnessctl set 5%-",
        "tooltip-format": "{percent}%"
    },
    "custom/playerctl": {
        "interval": 1,
        "format": "{icon} {text}",
        "max-length": 40,
        "exec": "~/.config/waybar/scripts/playerctl.sh",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "scroll-step": 10,
        "return-type": "json",
        "format-icons": {
            "Firefox": "<span color='#f38ba8'><b> </b></span>",
            "Playing": "<span color='#b4befe'><b>󰎈</b></span>",
            "Paused": "<span color='#f9e2af'><b>󰏤</b></span>",
        },
        "escape": true
    },
}
