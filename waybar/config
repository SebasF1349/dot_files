 {
  "layer": "top",
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [],
  "modules-right": [
    "network",
    "backlight",
    "pulseaudio",
    "battery",
    "clock",
  ],
  "hyprland/workspaces": {
    "disable-scroll": false,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "on-click": "activate"
  },
  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "exec": "~/.config/waybar/scripts/wabar-wttr.py",
    "return-type": "json"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "clock": {
    "format": "{:%a %b %d %I:%M %p}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    //"format": "{:%H:%M %a %d/%m}",
    "on-scroll": {
      "calendar": 1
    }
  },
  //"network": {
    //"format": "{ifname}",
    //"format-wifi": "ΎΘτ {signalStrength}%",
    //"format-ethernet": "≤░ΛΩ {ipaddr}/{cidr}",
    //"format-disconnected": "≤░Ψς", 
    //"tooltip-format": "{ifname} via {gwaddr}",
    //"tooltip-format-wifi": "{essid}",
    //"tooltip-format-ethernet": "{ifname}",
    //"tooltip-format-disconnected": "Disconnected",
    //"max-length": 50
  //},
  "network": {
    "interface": "wlan0",
    "format-icons": ["≤░νθ","≤░νλ","≤░νξ","≤░Ψσ"],
    "format": "Disconnected ≤░νφ", 
    "format-wifi":"On {icon}",
    "format-disconnected": "Offline ≤░νφ",
    "format-ethernet": "{ipaddr}/{cidr}≤░ΛΩ",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname}",
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{volume} {icon}",
    "format-bluetooth": "{volume}% ΎΛΦ {format_source}",
    "format-bluetooth-muted": "≤░ζθ  ΎΛΦ",
    "format-muted": "≤░ζθ ",
    // "format-source": "{volume}% ΎΕ░",
    // "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "≤░ΜΟ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ ",
      "deactivated": "ΎΒ░ "
    },
    "tooltip": false
  },
  "custom/power-menu": {
    "format": "έΠ╗",
    "on-click": "~/.config/waybar/scripts/power-menu/powermenu.sh"
  },
  "battery": {
    "interval": 10,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{capacity} {icon}",
    "format-icons": ["ΎΚΕ ", "ΎΚΔ ", "ΎΚΓ ", "ΎΚΒ ", "ΎΚΑ "],
    "format-full": "{capacity} {icon}",
    "format-charging": "{capacity}  <span color='#a6e3a1'>{icon}</span>",
    "tooltip": true,
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent} {icon}",
    "format-icons": [
      "≤░Δη",
      "≤░Δθ",
      "≤░Δι"
    ],
    "on-click": "brightnessctl set 5%+",
    "on-click-right": "brightnessctl set 5%-",
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6,
    "tooltip-format": "brightnessctl"
  },
}
