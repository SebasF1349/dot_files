{
	"workbench.iconTheme": "material-icon-theme",
	"eslint.run": "onSave",
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"explorer.confirmDelete": false,
	"git.autofetch": true,
	"git.confirmSync": false,
	"editor.wordWrap": "wordWrapColumn",
	"editor.wordWrapColumn": 100,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"editor.acceptSuggestionOnEnter": "off",
	"html.format.wrapLineLength": 0,
	"prettier.printWidth": 100,
	"editor.bracketPairColorization.enabled": true,
	"prettier.useTabs": true,
	"prettier.tabWidth": 4,

	"files.associations": {
		"header.ejs": "ejs" // this create the language « ejs » which refers to any .ejs file
	},
	"[ejs]": {
		// custom settings for the language « ejs »
		"editor.formatOnSave": false
	},
	"svelte.enable-ts-plugin": true,
	"editor.guides.bracketPairs": true,
	"editor.codeActionsOnSave": {
		"source.fixAll": true,
		"source.sortImports": false
	},
	"editor.stickyScroll.enabled": true,
	"workbench.sideBar.location": "right",
	"editor.minimap.enabled": false,
	"breadcrumbs.enabled": false,
	"lldb.suppressUpdateNotifications": true,
	"todohighlight.isEnable": true,
	"todohighlight.isCaseSensitive": true,
	"todohighlight.keywords": [
		"DEBUG:",
		"REVIEW:",
		{
			"text": "NOTE:",
			"color": "#ff0000"
			//"backgroundColor": "yellow",
			//"overviewRulerColor": "grey"
		},
		{
			"text": "HACK:",
			"color": "#000",
			"isWholeLine": false
		},
		{
			"text": "TODO:"
			//"color": "red",
			//"border": "1px solid red"
			//"borderRadius": "2px" //NOTE: using borderRadius along with `border` or you will see nothing change
			//"backgroundColor": "rgba(0,0,0,.2)"
			//other styling properties goes here ...
		},
		{
			"text": "FIXED:"
		}
	],
	"todohighlight.include": [
		"**/*.js",
		"**/*.jsx",
		"**/*.ts",
		"**/*.tsx",
		"**/*.html",
		"**/*.php",
		"**/*.css",
		"**/*.scss"
	],
	"todohighlight.exclude": [
		"**/node_modules/**",
		"**/bower_components/**",
		"**/dist/**",
		"**/build/**",
		"**/.vscode/**",
		"**/.github/**",
		"**/_output/**",
		"**/*.min.*",
		"**/*.map",
		"**/.next/**"
	],
	"todohighlight.maxFilesForSearch": 5120,
	"todohighlight.toggleURI": false,
	"svelte.plugin.svelte.note-new-transformation": false,
	//"editor.fontFamily": "'Atkinson Hyperlegible",
	"editor.fontFamily": "'JetBrains Mono'",
	//, Consolas, 'Courier New', monospace",
	"editor.fontLigatures": false,
	/*"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"name": "envKeys",
				"scope": "string.quoted.single.ini,constant.numeric.ini,string.quoted.double.ini",
				"settings": {
					"foreground": "#19354900"
				}
			},
			{
				"scope": "keyword.other.dotenv",
				"settings": {
					"foreground": "#FF000005"
				}
			}
		]
	},*/
	"files.exclude": {
		"*.env*": false
	},
	"SAMMI.bridge.extraPaths": [
		{
			"name": "Secondary Bridge",
			"path": "D:\\SAMMI\\bridge\\bridge-testing.html"
		},
		{
			"name": "Another Bridge",
			"path": "D:\\SAMMI\\bridge\\bridge-testing2.html"
		},
		{
			"name": "Real Bridge",
			"path": "D:\\Trabajos\\SAMMI\\SAMMI\\bridge\\bridge.html"
		}
	],
	"SAMMI.bridge.mainPath": "D:\\Trabajos\\SAMMI\\SAMMI\\bridge\\bridge.html",
	"workbench.colorTheme": "GitHub Dark Default",
	"workbench.editor.labelFormat": "short",
	"workbench.tree.indent": 16,
	"editor.linkedEditing": true,
	"editor.cursorSmoothCaretAnimation": "on",
	"githubPullRequests.pullBranch": "never",
	"telemetry.telemetryLevel": "off",
	"editor.formatOnPaste": true,
	"window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${profileName}",
	"editor.tabCompletion": "on",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"workbench.editor.enablePreview": false,
	"editor.suggest.showStatusBar": true,
	"window.menuBarVisibility": "toggle",
	"javascript.updateImportsOnFileMove.enabled": "always",
	"editor.scrollbar.horizontal": "hidden",
	"editor.scrollbar.vertical": "hidden",
	"workbench.editor.showTabs": false,
	"workbench.editor.limit.enabled": true,
	"workbench.editor.limit.perEditorGroup": true,
	"workbench.editor.limit.value": 1,
	"glassit.alpha": 220,
	"git.openRepositoryInParentFolders": "never",
	//"terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font Mono'",
	"terminal.integrated.fontFamily": "'JetBrains Mono'",
	"debug.console.fontFamily": "'JetBrains Mono'",
	"scm.inputFontFamily": "'JetBrains Mono'",
	"editor.codeLensFontFamily": "'JetBrains Mono'",
	"editor.inlayHints.fontFamily": "'JetBrains Mono'",
	"errorLens.fontFamily": "'JetBrains Mono'",
	"notebook.output.fontFamily": "'JetBrains Mono'",
	"interactiveSession.editor.fontFamily": "'JetBrains Mono'",
	"rust-analyzer.checkOnSave.command": "clippy",
	"[rust]": {
		"editor.defaultFormatter": "rust-lang.rust-analyzer",
		"editor.formatOnSave": true
	},
	"[cpp]": {
		"editor.defaultFormatter": "ms-vscode.cpptools"
	},
	"security.workspace.trust.untrustedFiles": "open",
	"workbench.panel.defaultLocation": "right",
	"workbench.activityBar.visible": false
}
